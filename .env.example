AWS_REGION=ap-northeast-2
# IAM Role(EC2 Instance Profile) 사용 시 비워둡니다.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_RAW_BUCKET=
AWS_S3_MODEL_BUCKET=
AWS_S3_PRED_BUCKET=
TRAIN_QUEUE_URL=
INFER_QUEUE_URL=
WANDB_API_KEY=
WANDB_PROJECT=
WANDB_ENTITY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=
SLACK_TARGET_CHANNEL_NAME=

TMDB_API_KEY=
API_MODEL_S3_KEY=
QUALITY_GATE_REQUIRED=false

# Database connection (priority: DB_* > MYSQL_* > defaults)
# For Aurora/RDS: Set DB_HOST to Terraform output active_db_endpoint
# For local Docker: Set DB_HOST=localhost or DB_HOST=db (container name)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=mlops
DB_AUTO_FAILOVER=true
DB_FALLBACK_HOSTS=db,localhost,127.0.0.1,host.docker.internal
DB_PROBE_TIMEOUT_SECONDS=0.6
SECONDARY_DB_HOST=
SECONDARY_DB_PORT=3306

# Legacy MySQL variables (for backward compatibility)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=mlops
MYSQL_ANALYZE_ID_TABLE=analyze_id_prediction_logs
MYSQL_CONNECT_TIMEOUT_SECONDS=2

SSM_WANDB_API_KEY_PARAM=/team-prj-group3/dev/mlops/WANDB_API_KEY
SSM_SLACK_BOT_TOKEN_PARAM=/team-prj-group3/dev/mlops/SLACK_BOT_TOKEN
SSM_SLACK_SIGNING_SECRET_PARAM=/team-prj-group3/dev/mlops/SLACK_SIGNING_SECRET
SSM_SLACK_APP_TOKEN_PARAM=/team-prj-group3/dev/mlops/SLACK_APP_TOKEN
SSM_TMDB_API_KEY_PARAM=/team-prj-group3/dev/mlops/TMDB_API_KEY