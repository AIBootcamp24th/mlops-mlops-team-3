# 원격 배포 설정 템플릿 (GitHub 업로드용)
# 이 파일을 remote.env로 복사 후 실제 값으로 채우세요.
# cp remote.env.example remote.env

# AWS API 배포 스크립트용
AWS_PROFILE=
AWS_REGION=ap-northeast-2
INSTANCE_ID=
INSTANCE_AZ=
REMOTE_HOST=
REMOTE_USER=
REMOTE_PORT=
SSH_KEY=
REMOTE_DIR=
API_PORT=8000
API_CORS_ALLOW_ORIGINS=*
PRUNE_REMOTE=true
SKIP_BUILD=false

# GPU 학습 배포 스크립트용 (기존)
# REMOTE_HOST/REMOTE_USER/REMOTE_PORT/SSH_KEY 재사용
